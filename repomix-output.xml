        content.append(Spacer(1, 0.1*inch))
    
    # =========================================================================
    # 8. PLAN DE TRATAMIENTO
    # =========================================================================
    plan = historia_data.get('plan_tratamiento', [])
    if plan:
        content.append(Paragraph("8. PLAN DE TRATAMIENTO", heading_style))
        content.append(Spacer(1, 0.1*inch))
        
