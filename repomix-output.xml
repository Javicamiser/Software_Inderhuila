                >
                  Cancelar
                </button>
                <button
                  onClick={handleGuardarEdicion}
                  disabled={isLoading}
                  style={{ backgroundColor: '#0369A1' }}
                  className="px-4 py-2 text-white rounded-lg hover:opacity-90 transition-colors disabled:opacity-50"
                >
                  {isLoading ? 'Guardando...' : 'Guardar Cambios'}
                </button>
              </div>
            </div>
          </div>
