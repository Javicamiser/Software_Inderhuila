    if not q or len(q) < 2:
        raise HTTPException(status_code=400, detail="El término de búsqueda debe tener al menos 2 caracteres")
    
    resultados = db.query(Deportista).filter(
        or_(
            Deportista.nombres.ilike(f"%{q}%"),
            Deportista.apellidos.ilike(f"%{q}%"),
