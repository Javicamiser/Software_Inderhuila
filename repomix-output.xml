                <p className="text-3xl font-bold text-gray-900 mt-2">
                  {reporteData.totalCitas}
                </p>
              </div>
              <div className="p-3 bg-red-100 rounded-lg">
                <Calendar className="w-8 h-8 text-red-600" />
              </div>
            </div>
          </div>

          {/* Historias */}
          <div className="bg-white rounded-lg shadow p-6">
