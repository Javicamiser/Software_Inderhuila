            for lesion in historia_data.get('lesiones_deportivas', []):
                desc = lesion.get('descripcion', '') or lesion.get('tipo_lesion', '')
                fecha = lesion.get('fecha_ultima_lesion', '') or lesion.get('fecha_lesion', '')
                obs = lesion.get('observaciones', '')
