    cita = actualizar_cita(db, cita_id, data)
    if not cita:
        raise HTTPException(status_code=404, detail="Cita no encontrada")
    return cita

@router.delete("/{cita_id}", status_code=204)
def eliminar(cita_id: str, db: Session = Depends(get_db)):
