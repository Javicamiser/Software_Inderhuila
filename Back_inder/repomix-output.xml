# Identificadores de las 9 secciones que el frontend puede seleccionar
SECCIONES_VALIDAS = {
    "motivo_consulta",
    "antecedentes",
    "revision_sistemas",
    "signos_vitales",
    "exploracion_fisica",
    "pruebas_complementarias",
