app = FastAPI(
    title=settings.APP_NAME,
    version="0.1.0",
    description="Backend Historia Clinica Deportiva - INDER"
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
