                      <X className="w-4 h-4 text-gray-600" />
                    </button>
                  </div>
                )}
              </div>

              {/* Tipo de cita */}
              <div>
                <label htmlFor="tipoCita" className="block mb-2 text-gray-700 font-medium">
                  Tipo de Cita <span className="text-red-500">*</span>
                </label>
                <select
                  id="tipoCita"
                  value={formData.tipo_cita_id}
