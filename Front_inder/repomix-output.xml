        setError('Error al cargar los catálogos');
      } finally {
        setLoading(false);
      }
    };

    cargarCatalogos();
  }, []);

  return {
    tiposDocumento,
    sexos,
    estados,
    tiposCita,
    estadosCita,
    loading,
    error,
  };
}

