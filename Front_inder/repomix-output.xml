import { BrowserRouter, Routes, Route, Navigate, useParams, useNavigate } from 'react-router-dom';
import { Toaster } from 'sonner';
import { CatalogosProvider } from './app/contexts/CatalogosContext';
import { DashboardLayout } from './app/components/layout/DashboardLayout';
import { lazy, Suspense } from 'react';

// ── Features reorganizadas ───────────────────────────────────
const Inicio               = lazy(() => import('./app/components/Inicio').then(m => ({ default: m.Inicio ?? m.default })));
const ListadoDeportistas   = lazy(() => import('./app/components/features/deportistas/ListadoDeportistas').then(m => ({ default: m.ListadoDeportistas ?? m.default })));
const ListadoHistoriaClinica = lazy(() => import('./app/components/features/historia/ListadoHistoriaClinica').then(m => ({ default: m.ListadoHistoriaClinica ?? m.default })));
const VistaHistoriaClinica = lazy(() => import('./app/components/features/historia/VistaHistoriaClinica').then(m => ({ default: m.VistaHistoriaClinica ?? m.default })));
const GestionCitas         = lazy(() => import('./app/components/features/citas/GestionCitas').then(m => ({ default: m.GestionCitas ?? m.default })));
const ArchivosGestion      = lazy(() => import('./app/components/features/archivos/ArchivosGestion').then(m => ({ default: m.ArchivosGestion ?? m.default })));
const Reportes             = lazy(() => import('./app/components/features/reportes/Reportes').then(m => ({ default: m.Reportes ?? m.default })));

function Spinner() {
  return (
    <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', minHeight: '60vh' }}>
      <div style={{ width: 32, height: 32, border: '2px solid #1F4788', borderTopColor: 'transparent', borderRadius: '50%', animation: 'spin 0.8s linear infinite' }} />
      <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
    </div>
  );
}

function Wrap({ children }: { children: React.ReactNode }) {
  return <Suspense fallback={<Spinner />}>{children}</Suspense>;
}

function VistaHistoriaWrapper() {
  const { id } = useParams<{ id: string }>();
  const navigate = useNavigate();
  if (!id) return <Navigate to="/historia" replace />;
  return (
    <Wrap>
      <VistaHistoriaClinica
        historiaId={id}
        onNavigate={(view) => navigate(`/${view}`)}
      />
    </Wrap>
  );
}

export default function App() {
  return (
    <BrowserRouter>
      <CatalogosProvider>
        <Toaster position="top-right" richColors />
        <Routes>
          <Route path="/" element={<DashboardLayout />}>
            <Route index element={<Navigate to="/dashboard" replace />} />
            <Route path="dashboard"    element={<Wrap><Inicio /></Wrap>} />
            <Route path="deportistas"  element={<Wrap><ListadoDeportistas /></Wrap>} />
            <Route path="historia"     element={<Wrap><ListadoHistoriaClinica /></Wrap>} />
            <Route path="historia/:id" element={<VistaHistoriaWrapper />} />
            <Route path="citas"        element={<Wrap><GestionCitas /></Wrap>} />
            <Route path="archivos"     element={<Wrap><ArchivosGestion /></Wrap>} />
            <Route path="reportes"     element={<Wrap><Reportes /></Wrap>} />
          </Route>
          <Route path="*" element={<Navigate to="/dashboard" replace />} />
        </Routes>
      </CatalogosProvider>
    </BrowserRouter>
  );
}
