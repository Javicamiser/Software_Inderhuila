                <p style={{ margin: 0, fontSize: 13, fontWeight: 600, color: '#0f172a' }}>Administrador</p>
                <p style={{ margin: '2px 0 0', fontSize: 11, color: '#94a3b8' }}>admin@inderhuila.gov.co</p>
