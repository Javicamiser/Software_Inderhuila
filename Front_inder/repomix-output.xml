      }}
      onMouseEnter={e => { (e.currentTarget as HTMLElement).style.background = danger ? '#fef2f2' : '#f8fafc'; }}
      onMouseLeave={e => { (e.currentTarget as HTMLElement).style.background = 'transparent'; }}
    >
      {icon}{label}
    </button>
  );
}

export default Topbar;
